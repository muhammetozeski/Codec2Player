<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.codec2.player">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      Kucuk KURULU boyutun anahtarlari:
      - debuggable="true"        -> sistem dex2oat ile odex/vdex/art URETMEZ (run-from-apk),
                                    kurulu boyut ~ base.apk kadar kalir. (Release lint'i patlar;
                                    derlemede -x lintVitalRelease ile gecilir.)
      - vmSafeMode="true"        -> AOT optimizasyonunu kapatir.
      - hardwareAccelerated="false" -> GPU shader onbellek dosyalari olusmaz.
      - allowBackup="false"      -> yedekleme veri klasoru ayrilmaz.
      - extractNativeLibs="false"-> .so kurulumda lib/'e KOPYALANMAZ (APK'dan mmap edilir);
                                    kurulu boyut sismez.
    -->
    <application
        android:debuggable="true"
        android:allowBackup="false"
        android:hardwareAccelerated="false"
        android:vmSafeMode="true"
        android:extractNativeLibs="false"
        android:label="@string/app_name"
        android:theme="@android:style/Theme.DeviceDefault.NoActionBar">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- .c2 dosyasini disaridan ac (octet-stream) -->
            <intent-filter android:priority="1">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:host="*" />
                <data android:mimeType="application/octet-stream" />
            </intent-filter>
            <!-- .c2 uzantisina gore -->
            <intent-filter android:priority="1">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:host="*" />
                <data android:pathPattern=".*\\.c2" />
                <data android:pathPattern=".*\\..*\\.c2" />
            </intent-filter>
            <!-- paylas: tekli ve coklu -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/octet-stream" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/octet-stream" />
            </intent-filter>
        </activity>

        <service
            android:name=".PlaybackService"
            android:exported="false" />
    </application>
</manifest>
